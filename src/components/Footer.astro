---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-container">

    <div class="footer-col brand-col">
      <h3>🔗 Creating Links</h3>
      <p>Empowering children and families through specialized therapy, education, and compassionate care in Bengaluru.</p>
      <p class="tagline">A way to redesign your life.</p>
    </div>

    <div class="footer-col">
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/team">Our Team</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Our Services</h4>
      <ul>
        <li><a href="/services#occupational-therapy">Occupational Therapy</a></li>
        <li><a href="/services#speech-therapy">Speech Therapy</a></li>
        <li><a href="/services#school-readiness">School Readiness</a></li>
        <li><a href="/services#behavioral-therapy">Behavioral Therapy</a></li>
        <li><a href="/services#special-education">Special Education</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contact Us</h4>
      <p>📍 4C, 912, 4th Cross, HRBR Layout 1st Block, Kalyan Nagar, Bengaluru 560043</p>
      <p>📞 <a href="tel:+918185272466">+91 81852 72466</a></p>
      <p>✉️ <a href="mailto:creatinglinks22@gmail.com">creatinglinks22@gmail.com</a></p>
    </div>

  </div>

  <div class="footer-bottom">
    <p>&copy; {currentYear} Creating Links Therapy & Development Centre. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: #1a2332;
    color: #d1d5db;
    padding-top: 3.5rem;
    margin-top: auto;
  }

  .footer-container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.25rem 3rem;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.2fr;
    gap: 2.5rem;
  }

  .brand-col h3 {
    color: var(--color-primary);
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .tagline {
    font-style: italic;
    color: #9ca3af;
    font-size: 0.9rem;
  }

  h4 {
    color: #e5e7eb;
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  p {
    color: #9ca3af;
    line-height: 1.6;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    margin-bottom: 0.6rem;
  }

  a {
    color: #9ca3af;
    text-decoration: none;
    transition: color 0.2s;
    font-size: 0.9rem;
  }

  a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    background-color: rgba(0,0,0,0.25);
    text-align: center;
    padding: 1.25rem 0;
  }

  .footer-bottom p {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
