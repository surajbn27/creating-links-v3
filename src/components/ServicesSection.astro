---
/* Services preview for homepage — shows top 4 services as cards */
import servicesData from '../data/services.json';

// Show the first 4 services on the homepage
const previewServices = servicesData.slice(0, 4);
---

<section class="services-section">
  <div class="services-container">
    <div class="section-header">
      <h2>Our Therapy Services</h2>
      <p>Comprehensive, evidence-based care tailored to your child's developmental journey.</p>
    </div>

    <div class="grid">
      {previewServices.map((service) => (
        <a href={`/services#${service.id}`} class="service-card">
          <div class="icon-wrapper">
            <span class="icon">{service.icon}</span>
          </div>
          <h3>{service.title}</h3>
          <p>{service.shortDescription}</p>
          <span class="learn-more">Learn More →</span>
        </a>
      ))}
    </div>

    <div class="view-all">
      <a href="/services" class="btn btn-outline">View All Services</a>
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 5rem 1.25rem;
    background: white;
  }

  .services-container {
    max-width: 1140px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    font-size: 2.25rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .section-header p {
    max-width: 550px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    display: block;
    background: white;
    padding: 2rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    border: 1px solid #f3f4f6;
    text-align: center;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .icon-wrapper {
    background: var(--color-bg-light);
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }

  .icon { font-size: 1.75rem; }

  h3 {
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    font-size: 1.15rem;
  }

  p {
    color: var(--color-text-body);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .learn-more {
    color: var(--color-secondary);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .view-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
