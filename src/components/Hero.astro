---
/* Hero v2.0 — Creating Links homepage hero */
---

<section class="hero">
  <div class="hero-container">
    <div class="hero-content">
      <span class="hero-badge">Bengaluru's Trusted Child Development Centre</span>
      <h1>Empowering Every Child's <span class="highlight">Unique Potential</span></h1>
      <p>
        At Creating Links, we provide holistic, evidence-based therapy — from occupational
        therapy and speech therapy to school readiness programs — tailored to your child's
        developmental journey. We don't just treat; we build lasting connections.
      </p>
      <div class="hero-buttons">
        <a href="/contact" class="btn btn-primary">Book an Assessment</a>
        <a href="/services" class="btn btn-outline">Our Services</a>
      </div>
      <div class="hero-trust">
        <div class="trust-item">
          <span class="trust-icon">👨‍⚕️</span>
          <span>Certified Therapists</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">🧩</span>
          <span>Individualized Plans</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">👪</span>
          <span>Family-Centered Care</span>
        </div>
      </div>
    </div>

    <div class="hero-image">
      <img src="https://placehold.co/580x420/267c88/white?text=Therapy+Session" alt="A therapy session at Creating Links" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 4rem 1.25rem 5rem;
    background: linear-gradient(180deg, var(--color-bg-light) 0%, var(--color-bg-white) 100%);
  }

  .hero-container {
    max-width: 1140px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .hero-content h1 {
    font-size: 2.75rem;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .highlight {
    color: var(--color-primary);
  }

  .hero-content p {
    font-size: 1.1rem;
    color: var(--color-text-body);
    margin-bottom: 2rem;
    max-width: 540px;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  /* Trust indicators */
  .hero-trust {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .trust-icon {
    font-size: 1.1rem;
  }

  /* Image */
  .hero-image img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2.5rem 1rem 3rem;
    }
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-content h1 {
      font-size: 2rem;
    }
    .hero-content p {
      margin-left: auto;
      margin-right: auto;
    }
    .hero-buttons {
      justify-content: center;
    }
    .hero-trust {
      justify-content: center;
    }
    .hero-image {
      order: -1;
    }
  }
</style>
