---
// =============================================================
// Hero.astro — Homepage hero section
//
// Layout: two-column grid (text left, image right)
// Contains:
//   - Trust badge
//   - Headline + subtext
//   - Two CTA buttons (Book Assessment / Our Services)
//   - Three trust indicators (Certified, Individualized, Family-Centered)
// =============================================================
---

<section class="hero">
  <div class="hero-container">

    <!-- Left column: text content -->
    <div class="hero-content">

      <span class="hero-badge">Bengaluru's Trusted Child Development Centre</span>

      <h1>
        Empowering Every Child's
        <span class="highlight">Unique Potential</span>
      </h1>

      <p>
        At Creating Links, we provide holistic, evidence-based therapy — from occupational
        therapy and speech therapy to school readiness programs — tailored to your child's
        developmental journey. We don't just treat; we build lasting connections.
      </p>

      <!-- CTA buttons -->
      <div class="hero-buttons">
        <a href="/contact" class="btn btn-primary">Book an Assessment</a>
        <a
          href="https://wa.me/918105272466?text=Hi%2C%20I%20would%20like%20to%20enquire%20about%20therapy%20services."
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-whatsapp"
        >💬 Chat on WhatsApp</a>
      </div>

      <!-- Three quick trust signals below the buttons -->
      <div class="hero-trust">
        <div class="trust-item">
          <span class="trust-icon">👨‍⚕️</span>
          <span>Certified Therapists</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">🧩</span>
          <span>Individualized Plans</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon">👪</span>
          <span>Family-Centered Care</span>
        </div>
      </div>

    </div>

    <!-- Right column: hero image placeholder -->
    <div class="hero-image">
      <div class="image-placeholder">
        <span class="placeholder-icon">🏥</span>
        <span class="placeholder-text">Image Coming Soon</span>
      </div>
    </div>

  </div>
</section>

<style>
  /* ---- Hero wrapper ---- */
  .hero {
    padding: 4rem 1.25rem 5rem;
    background: linear-gradient(180deg, var(--color-bg-light) 0%, var(--color-bg-white) 100%);
  }

  /* Two-column layout on desktop */
  .hero-container {
    max-width: 1140px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* ---- Badge ---- */
  .hero-badge {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  /* ---- Headline ---- */
  .hero-content h1 {
    font-size: 2.75rem;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  /* Teal highlight on the second line of the headline */
  .highlight {
    color: var(--color-primary);
  }

  /* ---- Body text ---- */
  .hero-content p {
    font-size: 1.1rem;
    color: var(--color-text-body);
    margin-bottom: 2rem;
    max-width: 540px;
  }

  /* ---- CTA buttons row ---- */
  .hero-buttons {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .btn-whatsapp {
    background-color: #25D366;
    color: white !important;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: background-color 0.2s;
  }

  .btn-whatsapp:hover {
    background-color: #1DA851;
  }

  /* ---- Trust indicators ---- */
  .hero-trust {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .trust-icon {
    font-size: 1.1rem;
  }

  /* ---- Hero image placeholder ---- */
  .hero-image .image-placeholder {
    width: 100%;
    min-height: 420px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--color-primary) 0%, #1a5c66 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    box-shadow: var(--shadow-lg);
  }

  .placeholder-icon {
    font-size: 3rem;
    opacity: 0.7;
  }

  .placeholder-text {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
    font-weight: 500;
  }

  /* ---- Mobile: stack columns vertically ---- */
  @media (max-width: 768px) {
    .hero {
      padding: 2.5rem 1rem 3rem;
    }

    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-content h1 {
      font-size: 2rem;
    }

    /* Centre the paragraph text on mobile */
    .hero-content p {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-buttons {
      justify-content: center;
    }

    .hero-trust {
      justify-content: center;
    }

    /* Image appears above text on mobile */
    .hero-image {
      order: -1;
    }
  }
</style>
