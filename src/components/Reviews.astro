---
// =============================================================
// Reviews.astro — Parent testimonials section
//
// Reads all reviews from reviews.json and renders them in a
// responsive grid of cards. Each card shows:
//   - Star rating
//   - Review text (in quotes)
//   - Parent name, child age, and service tag
// =============================================================

import reviewsData from '../data/reviews.json';
---

<section class="reviews-section">
  <div class="reviews-container">

    <!-- Section heading -->
    <div class="section-header">
      <h2>What Parents Say</h2>
      <p>Real stories from families we've supported on their journey.</p>
      <div class="google-badge">
        <span class="google-stars">⭐⭐⭐⭐⭐</span>
        <span class="google-rating">5.0 rating on Google (15 reviews)</span>
      </div>
    </div>

    <!-- Responsive grid of review cards -->
    <div class="reviews-grid">
      {reviewsData.map((review) => (
        <div class="review-card">

          <!-- Star rating (repeated emoji based on rating value) -->
          <div class="stars">{"⭐".repeat(review.rating)}</div>

          <!-- Review body text -->
          <p class="review-text">"{review.review}"</p>

          <!-- Reviewer identity -->
          <div class="reviewer-info">
            <strong>{review.parent_name}</strong>
            <span class="child-info">via Google Reviews</span>
          </div>

        </div>
      ))}
    </div>

    <!-- Link to full Google Reviews -->
    <div class="google-link">
      <a
        href="https://www.google.com/maps/place/Creating+Links/data=!4m2!3m1!1s0x3bae17fae7ddd857:0xfade801edcfd17f3"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline"
      >
        See All Reviews on Google →
      </a>
    </div>

  </div>
</section>

<style>
  /* ---- Section wrapper ---- */
  .reviews-section {
    background: var(--color-bg-light);
    padding: 5rem 1.25rem;
  }

  .reviews-container {
    max-width: 1140px;
    margin: 0 auto;
  }

  /* ---- Section heading ---- */
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    color: var(--color-primary);
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .section-header p {
    max-width: 500px;
    margin: 0 auto;
  }

  .google-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .google-stars {
    font-size: 1rem;
    letter-spacing: 1px;
  }

  .google-rating {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  /* ---- Cards grid ---- */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  /* ---- Individual review card ---- */
  .review-card {
    background: white;
    padding: 2rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    border: 1px solid #f3f4f6;
  }

  .stars {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  /* Italic quoted review text */
  .review-text {
    font-size: 1.05rem;
    color: var(--color-text-body);
    font-style: italic;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  /* Parent name (bold, full-width block) */
  .reviewer-info strong {
    display: block;
    color: var(--color-text-main);
    font-size: 1rem;
  }

  /* "Parent of child (age)" line */
  .child-info {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  /* Link to all Google reviews */
  .google-link {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* ---- Mobile: single column ---- */
  @media (max-width: 768px) {
    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
