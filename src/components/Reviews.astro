---
// =============================================================
// Reviews.astro — Parent testimonials section
//
// Reads all reviews from reviews.json and renders them in a
// responsive grid of cards. Each card shows:
//   - Star rating
//   - Review text (in quotes)
//   - Parent name, child age, and service tag
// =============================================================

import reviewsData from '../data/reviews.json';
---

<section class="reviews-section">
  <div class="reviews-container">

    <!-- Section heading -->
    <div class="section-header">
      <h2>What Parents Say</h2>
      <p>Real stories from families we've supported on their journey.</p>
    </div>

    <!-- Responsive grid of review cards -->
    <div class="reviews-grid">
      {reviewsData.map((review) => (
        <div class="review-card">

          <!-- Star rating (repeated emoji based on rating value) -->
          <div class="stars">{"⭐".repeat(review.rating)}</div>

          <!-- Review body text -->
          <p class="review-text">"{review.review}"</p>

          <!-- Reviewer identity -->
          <div class="reviewer-info">
            <strong>{review.parent_name}</strong>
            <span class="child-info">Parent of child ({review.child_age})</span>
            <span class="service-tag">{review.service}</span>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* ---- Section wrapper ---- */
  .reviews-section {
    background: var(--color-bg-light);
    padding: 5rem 1.25rem;
  }

  .reviews-container {
    max-width: 1140px;
    margin: 0 auto;
  }

  /* ---- Section heading ---- */
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    color: var(--color-primary);
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .section-header p {
    max-width: 500px;
    margin: 0 auto;
  }

  /* ---- Cards grid ---- */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  /* ---- Individual review card ---- */
  .review-card {
    background: white;
    padding: 2rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    border: 1px solid #f3f4f6;
  }

  .stars {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  /* Italic quoted review text */
  .review-text {
    font-size: 1.05rem;
    color: var(--color-text-body);
    font-style: italic;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  /* Parent name (bold, full-width block) */
  .reviewer-info strong {
    display: block;
    color: var(--color-text-main);
    font-size: 1rem;
  }

  /* "Parent of child (age)" line */
  .child-info {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  /* Coloured pill showing which service they used */
  .service-tag {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* ---- Mobile: single column ---- */
  @media (max-width: 768px) {
    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
