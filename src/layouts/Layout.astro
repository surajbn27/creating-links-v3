---
// =============================================================
// Layout.astro — Root page layout used by every page
//
// Wraps content with:
//   - <head> meta tags (title, description, fonts)
//   - Navbar (top)
//   - <main> slot (page-specific content goes here)
//   - Footer (bottom)
//   - WhatsAppFloat button (fixed, bottom-right)
//
// Usage:
//   <Layout title="Page Title" description="Page description">
//     ... page content ...
//   </Layout>
// =============================================================

import '../styles/global.css';
import Navbar        from '../components/Navbar.astro';
import Footer        from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

// Props with sensible defaults (used as site-wide fallback)
interface Props {
  title?:       string;
  description?: string;
}

const {
  title       = "Creating Links — Holistic Wellness & Child Therapy Centre, Bengaluru",
  description = "Specialized speech therapy, occupational therapy, school readiness, and holistic child development in Bengaluru. Empowering families, enabling growth."
} = Astro.props;

// Build the canonical URL for this page
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Canonical URL — tells Google which URL is the "official" one -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph — used by WhatsApp, Facebook, LinkedIn when sharing -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="Creating Links" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content="https://creatinglinks.org/images/logo_dark.png" />
    <meta property="og:locale"      content="en_IN" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content="https://creatinglinks.org/images/logo_dark.png" />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts: Inter (weights 400–800) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>

  <body>
    <Navbar />

    <!-- Page content injected here by each individual page -->
    <main>
      <slot />
    </main>

    <Footer />

    <!-- Floating WhatsApp button (fixed bottom-right on all pages) -->
    <WhatsAppFloat />
  </body>
</html>
