---
// =============================================================
// contact.astro — Contact Us page
//
// Layout: two-column grid
//   Left  — enquiry form (Web3Forms)
//   Right — clinic info card + Google Maps embed
//
// Form submissions go to Web3Forms (no backend needed).
// Access key is specific to the Creating Links account.
// The botcheck hidden checkbox is a spam honeypot field.
// =============================================================

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us — Creating Links"
  description="Get in touch with Creating Links. Book an assessment, ask a question, or visit our clinic in Banaswadi, Bengaluru."
>

  <!-- Page header banner -->
  <section class="page-header">
    <div class="container">
      <h1>Contact Us</h1>
      <p>We're here to answer your questions and support your family's journey.</p>
    </div>
  </section>

  <!-- Main content: form + info sidebar -->
  <section class="contact-section">
    <div class="contact-container grid">

      <!-- ============ LEFT: Enquiry Form ============ -->
      <div class="form-wrapper">
        <h2>Send us a Message</h2>
        <p class="form-intro">
          Fill out the form below to schedule an assessment or ask a question.
          We typically respond within 24 hours.
        </p>

        <!--
          Web3Forms: form submissions are sent to hello@creatinglinks.org (via Web3Forms account)
          Access key: 35fbd206-d7e8-49fe-8814-07e5ecdb2337
          Docs: https://web3forms.com
        -->
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="contact-form"
        >
          <!-- Web3Forms authentication key (required) -->
          <input type="hidden" name="access_key" value="35fbd206-d7e8-49fe-8814-07e5ecdb2337" />

          <!-- Sender label shown in the notification email subject line -->
          <input type="hidden" name="from_name" value="Creating Links Website" />

          <!-- Replies to Web3Forms notifications go to the clinic email -->
          <input type="hidden" name="replyto" value="hello@creatinglinks.org" />

          <!-- Spam honeypot: bots fill this in, humans don't see it -->
          <input type="checkbox" name="botcheck" style="display: none;" />

          <!-- Parent name -->
          <div class="form-group">
            <label for="name">Parent's Name</label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Enter your full name"
              required
            />
          </div>

          <!-- Email -->
          <div class="form-group">
            <label for="email">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="email@example.com"
              required
            />
          </div>

          <!-- Phone -->
          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="+91 98765 43210"
              required
            />
          </div>

          <!-- Service selector — matches services in services.json -->
          <div class="form-group">
            <label for="service">Service of Interest</label>
            <select id="service" name="service">
              <option value="">Select a service (optional)</option>
              <option value="Early Intervention">Early Intervention</option>
              <option value="Occupational Therapy">Occupational Therapy</option>
              <option value="Sensory Integration">Sensory Integration</option>
              <option value="Behavioral Therapy">Behavioral Therapy</option>
              <option value="Speech Therapy">Speech & Language Therapy</option>
              <option value="Group Therapy">Group Therapy</option>
              <option value="School Readiness">School Readiness Program</option>
              <option value="Special Education">Special Education</option>
              <option value="Physiotherapy">Physiotherapy</option>
              <option value="Vocational Training">Vocational Training</option>
              <option value="Not Sure">Not sure — need guidance</option>
            </select>
          </div>

          <!-- Free-text message -->
          <div class="form-group">
            <label for="message">How can we help?</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder="Tell us a bit about your child's needs..."
              required
            ></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-full">Send Message</button>
        </form>
      </div>

      <!-- ============ RIGHT: Clinic Info + Map ============ -->
      <div class="info-wrapper">

        <!-- Contact details card -->
        <div class="info-card">
          <h3>Clinic Information</h3>

          <div class="info-item">
            <span class="info-icon">📍</span>
            <div>
              <strong>Address</strong>
              <p>
                We have moved to Creating Links, #18 Upasana,<br />
                3rd Cross, 9th Main, 1st Block, HRBR Layout,<br />
                Banaswadi, Bengaluru, Karnataka 560043<br />
                Landmark: Near Ibaco Ice Cream, diagonally opposite to Ibaco and approximately 100m away
              </p>
            </div>
          </div>

          <div class="info-item">
            <span class="info-icon">📞</span>
            <div>
              <strong>Phone</strong>
              <p><a href="tel:+918105272466">+91 81052 72466</a></p>
            </div>
          </div>

          <div class="info-item">
            <span class="info-icon">✉️</span>
            <div>
              <strong>Email</strong>
              <p><a href="mailto:hello@creatinglinks.org">hello@creatinglinks.org</a></p>
            </div>
          </div>

          <div class="info-item">
            <span class="info-icon">⏰</span>
            <div>
              <strong>Hours</strong>
              <p>All Days: 9:00 AM – 6:00 PM</p>
            </div>
          </div>

          <div class="info-item">
            <span class="info-icon">💬</span>
            <div>
              <strong>WhatsApp</strong>
              <p>
                <a
                  href="https://wa.me/918105272466?text=Hi%2C%20I%20would%20like%20to%20enquire%20about%20therapy%20services."
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Chat with us on WhatsApp
                </a>
              </p>
            </div>
          </div>
        </div>

        <!-- Google Maps embed (verified Creating Links pin) -->
        <div class="map-container">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3887.3363864100515!2d77.64424351155793!3d13.014237787252092!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bae17fae7ddd857%3A0xfade801edcfd17f3!2sCreating%20Links!5e0!3m2!1sen!2sin!4v1777654078157!5m2!1sen!2sin"
            width="100%"
            height="280"
            style="border: 0;"
            allowfullscreen=""
            loading="lazy"
            title="Creating Links Clinic Location"
          ></iframe>
        </div>

      </div>

    </div>
  </section>

</Layout>

<style>
  /* ---- Page layout ---- */
  .contact-section {
    padding: 4rem 1.25rem;
    background: white;
  }

  .contact-container {
    max-width: 1080px;
    margin: 0 auto;
  }

  /* Two-column grid: form (wider) | info sidebar */
  .grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
  }

  /* ---- Form styles ---- */
  .form-wrapper h2 {
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .form-intro {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  label {
    display: block;
    margin-bottom: 0.4rem;
    font-weight: 600;
    color: var(--color-text-main);
    font-size: 0.95rem;
  }

  /* Shared styles for all form inputs */
  input,
  textarea,
  select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius-sm);
    font-size: 1rem;
    font-family: inherit;     /* match Inter font, not browser default */
    transition: border-color 0.2s;
    background: white;
  }

  /* Teal focus ring on inputs */
  input:focus,
  textarea:focus,
  select:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(38, 124, 136, 0.1);
  }

  /* Full-width submit button */
  .btn-full {
    width: 100%;
    padding: 0.85rem;
    font-size: 1.05rem;
    margin-top: 0.5rem;
  }

  /* ---- Info card (right sidebar) ---- */
  .info-card {
    background: var(--color-bg-light);
    padding: 2rem;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  /* Card heading with underline separator */
  .info-card h3 {
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #e5e7eb;
    font-size: 1.25rem;
  }

  /* Each info row: icon + label + value */
  .info-item {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  /* Icon locked to top-left of its row */
  .info-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .info-item strong {
    display: block;
    color: var(--color-text-main);
    margin-bottom: 0.15rem;
    font-size: 0.9rem;
  }

  .info-item p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.5;
    font-size: 0.95rem;
  }

  .info-item a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .info-item a:hover {
    text-decoration: underline;
  }

  /* ---- Google Maps embed ---- */
  .map-container iframe {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  /* ---- Mobile: stack form above info card ---- */
  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
