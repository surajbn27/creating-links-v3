---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us — Creating Links" description="Get in touch with Creating Links. Book an assessment, ask a question, or visit our clinic in HRBR Layout, Bengaluru.">

  <section class="page-header">
    <div class="container">
      <h1>Contact Us</h1>
      <p>We're here to answer your questions and support your family's journey.</p>
    </div>
  </section>

  <section class="contact-section">
    <div class="contact-container grid">

      <!-- Form -->
      <div class="form-wrapper">
        <h2>Send us a Message</h2>
        <p class="form-intro">Fill out the form below to schedule an assessment or ask a question. We typically respond within 24 hours.</p>

        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="contact-form"
        >
          <input type="hidden" name="access_key" value="35fbd206-d7e8-49fe-8814-07e5ecdb2337" />
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

          <div class="form-group">
            <label for="name">Parent's Name</label>
            <input type="text" id="name" name="name" placeholder="Enter your full name" required />
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="email@example.com" required />
          </div>

          <div class="form-group">
            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="+91 98765 43210" required />
          </div>

          <div class="form-group">
            <label for="service">Service of Interest</label>
            <select id="service" name="service">
              <option value="">Select a service (optional)</option>
              <option value="Occupational Therapy">Occupational Therapy</option>
              <option value="Speech Therapy">Speech & Language Therapy</option>
              <option value="School Readiness">School Readiness Program</option>
              <option value="Behavioral Therapy">Behavioral Therapy</option>
              <option value="Special Education">Special Education</option>
              <option value="Physiotherapy">Physiotherapy</option>
              <option value="Sensory Integration">Sensory Integration</option>
              <option value="Early Intervention">Early Intervention</option>
              <option value="Group Therapy">Group Therapy</option>
              <option value="Vocational Training">Vocational Training</option>
              <option value="Not Sure">Not sure — need guidance</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">How can we help?</label>
            <textarea id="message" name="message" rows="4" placeholder="Tell us a bit about your child's needs..." required></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-full">Send Message</button>
        </form>
      </div>

      <!-- Info Sidebar -->
      <div class="info-wrapper">
        <div class="info-card">
          <h3>Clinic Information</h3>

          <div class="info-item">
            <span class="info-icon">📍</span>
            <div>
              <strong>Address</strong>
              <p>4C, 912, 4th Cross, HRBR Layout 1st Block,<br/>Kalyan Nagar, Bengaluru 560043</p>
            </div>
          </div>

          <div class="info-item">
            <span class="info-icon">📞</span>
            <div>
              <strong>Phone</strong>
              <p><a href="tel:+918105272466">+91 81052 72466</a></p>
            </div>
          </div>

          <div class="info-item">
            <span class="info-icon">✉️</span>
            <div>
              <strong>Email</strong>
              <p><a href="mailto:creatinglinks22@gmail.com">creatinglinks22@gmail.com</a></p>
            </div>
          </div>

          <div class="info-item">
            <span class="info-icon">⏰</span>
            <div>
              <strong>Hours</strong>
              <p>Mon – Sat: 9:00 AM – 7:00 PM<br/>Sunday: Closed</p>
            </div>
          </div>

          <div class="info-item">
            <span class="info-icon">💬</span>
            <div>
              <strong>WhatsApp</strong>
              <p><a href="https://wa.me/919945189289?text=Hi%2C%20I%20would%20like%20to%20enquire%20about%20therapy%20services." target="_blank">Chat with us on WhatsApp</a></p>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="map-container">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d7774.597676664828!2d77.65055600000001!3d13.016632!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bae17fae7ddd857%3A0xfade801edcfd17f3!2sCreating%20Links!5e0!3m2!1sen!2sus!4v1774095665755!5m2!1sen!2sus"
            width="100%"
            height="280"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            title="Creating Links Clinic Location">
          </iframe>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  .contact-section {
    padding: 4rem 1.25rem;
    background: white;
  }

  .contact-container {
    max-width: 1080px;
    margin: 0 auto;
  }

  .grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
  }

  /* Form Styles */
  .form-wrapper h2 {
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .form-intro {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  label {
    display: block;
    margin-bottom: 0.4rem;
    font-weight: 600;
    color: var(--color-text-main);
    font-size: 0.95rem;
  }

  input, textarea, select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius-sm);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.2s;
    background: white;
  }

  input:focus, textarea:focus, select:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(38, 124, 136, 0.1);
  }

  .btn-full {
    width: 100%;
    padding: 0.85rem;
    font-size: 1.05rem;
    margin-top: 0.5rem;
  }

  /* Info Card */
  .info-card {
    background: var(--color-bg-light);
    padding: 2rem;
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  .info-card h3 {
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #e5e7eb;
    font-size: 1.25rem;
  }

  .info-item {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .info-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .info-item strong {
    display: block;
    color: var(--color-text-main);
    margin-bottom: 0.15rem;
    font-size: 0.9rem;
  }

  .info-item p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.5;
    font-size: 0.95rem;
  }

  .info-item a {
    color: var(--color-primary);
    text-decoration: none;
  }
  .info-item a:hover {
    text-decoration: underline;
  }

  /* Map */
  .map-container iframe {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
