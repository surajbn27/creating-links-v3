---
// =============================================================
// index.astro — Homepage
//
// Section order:
//   1. Hero          (headline, CTA buttons, trust indicators)
//   2. Services      (preview of first 4 services)
//   3. School Readiness Highlight (signature program spotlight)
//   4. Reviews       (parent testimonials)
//   5. CTA Strip     (book an assessment)
// =============================================================

import Layout              from '../layouts/Layout.astro';
import Hero                from '../components/Hero.astro';
import ServicesSection      from '../components/ServicesSection.astro';
import Reviews             from '../components/Reviews.astro';
import IndianIllustration  from '../components/IndianIllustration.astro';
---

<Layout>

  <!-- 1. Hero banner -->
  <Hero />

  <!-- 2. Services preview grid -->
  <ServicesSection />

  <!-- 3. School Readiness Program spotlight -->
  <section class="highlight-section">
    <div class="highlight-container">

      <!-- Text content -->
      <div class="highlight-content">
        <span class="highlight-badge">Signature Program</span>
        <h2>School Readiness Program</h2>
        <p>
          Our structured program prepares children for mainstream schooling through three progressive
          levels — from building foundational imitation skills ("Wings to Fly") to achieving full
          academic and social readiness ("Sky's the Limit").
        </p>
        <ul class="highlight-features">
          <li>1:3 / 1:2 teaching ratio for personalized attention</li>
          <li>Data-driven monthly progress tracking</li>
          <li>CCTV-monitored safe environment</li>
          <li>Parent observation & regular feedback sessions</li>
        </ul>
        <a href="/services#school-readiness" class="btn btn-primary">Learn More</a>
      </div>

      <!-- Indian-themed illustrated visual -->
      <div class="highlight-image">
        <IndianIllustration icon="📚" palette="green" minHeight="380px" />
      </div>

    </div>
  </section>

  <!-- 4. Parent reviews -->
  <Reviews />

  <!-- 5. Bottom CTA strip -->
  <section class="cta-strip">
    <div class="container">
      <h2>Take the First Step Today</h2>
      <p>Book a free initial consultation and let our team understand your child's unique needs.</p>
      <a href="/contact" class="btn btn-white">Book an Assessment</a>
    </div>
  </section>

</Layout>

<style>
  /* ---- School Readiness Highlight section ---- */
  .highlight-section {
    padding: 5rem 1.25rem;
    background: var(--color-bg-light);
  }

  /* Two-column layout (text left, image right) */
  .highlight-container {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* ---- Badge ---- */
  .highlight-badge {
    display: inline-block;
    background: var(--color-secondary);
    color: white;
    padding: 0.3rem 0.9rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  /* ---- Heading & body copy ---- */
  .highlight-content h2 {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .highlight-content p {
    color: var(--color-text-body);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    font-size: 1.05rem;
  }

  /* ---- Feature bullet list ---- */
  .highlight-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
  }

  .highlight-features li {
    padding: 0.4rem 0;
    color: var(--color-text-main);
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Circular teal checkmark bullet */
  .highlight-features li::before {
    content: "✓";
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
    flex-shrink: 0;   /* prevent shrinking when text is long */
  }

  /* ---- Mobile: stack vertically, image above text ---- */
  @media (max-width: 768px) {
    .highlight-container {
      grid-template-columns: 1fr;
    }

    /* Illustration appears below the text on mobile (text is the priority) */
    .highlight-image {
      order: 1;
    }
  }
</style>
