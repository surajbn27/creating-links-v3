---
// =============================================================
// about.astro — About Us page
//
// Section order:
//   1. Page header   (teal banner)
//   2. Mission       (text + image, two-column)
//   3. Philosophy    (4 cards: IEP, Learning to Learn, Independence, Life Skills)
//   4. Why Choose Us (checklist + image, reversed two-column)
//   5. CTA Strip     (contact us)
// =============================================================

import Layout from '../layouts/Layout.astro';
import IndianIllustration from '../components/IndianIllustration.astro';
---

<Layout
  title="About Us — Creating Links"
  description="Learn about Creating Links, a child therapy and development centre in Bengaluru dedicated to empowering children and families."
>

  <!-- 1. Page header banner -->
  <section class="page-header">
    <div class="container">
      <h1>About Creating Links</h1>
      <p>A way to redesign your life — dedicated to empowering children and supporting families.</p>
    </div>
  </section>

  <!-- 2. Our Mission -->
  <section class="section">
    <div class="about-container grid">

      <div class="content">
        <h2>Our Mission</h2>
        <p>
          At Creating Links, we believe that every child possesses a unique set of strengths
          that deserve to be nurtured through specialized, intensive intervention. Our mission
          is to bridge the gap between home and the structured school environment by focusing
          on the holistic needs of every child.
        </p>
        <p>
          We are more than just a clinic — we are a multidisciplinary team of expert occupational
          therapists, speech-language pathologists, behavior intervention specialists, and special
          educators dedicated to your child's growth.
        </p>
      </div>

      <!-- Indian-themed illustration -->
      <div class="image-wrapper">
        <IndianIllustration icon="🌱" palette="green" minHeight="360px" />
      </div>

    </div>
  </section>

  <!-- 3. Our Philosophy (4 cards) -->
  <section class="section alt-bg">
    <div class="about-container">
      <div class="philosophy-grid">

        <div class="philosophy-card">
          <span class="card-icon">🌱</span>
          <h3>Individualized Growth</h3>
          <p>
            We use a comprehensive initial assessment to create a personalized Individualized
            Education Plan (IEP) tailored to your child's baseline in communication and
            social-emotional regulation.
          </p>
        </div>

        <div class="philosophy-card">
          <span class="card-icon">📖</span>
          <h3>"Learning to Learn" Philosophy</h3>
          <p>
            Our primary goal is to establish the behaviors necessary for a child to succeed
            in any educational setting through a supportive, data-driven approach.
          </p>
        </div>

        <div class="philosophy-card">
          <span class="card-icon">🚀</span>
          <h3>Pathways to Independence</h3>
          <p>
            From building foundational imitation skills to mastering personal safety and
            academic reasoning — we prepare children for full integration into mainstream
            school settings.
          </p>
        </div>

        <div class="philosophy-card">
          <span class="card-icon">❤️</span>
          <h3>Functional Life Skills</h3>
          <p>
            We prioritize real-world independence by teaching self-care routines, emotional
            regulation tools, and visual schedules that empower children for life.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. Why Choose Us (image on left, checklist on right) -->
  <section class="section">
    <div class="about-container grid reverse">

      <div class="content">
        <h2>Why Choose Creating Links?</h2>
        <ul class="check-list">
          <li>Experienced, certified therapists led by Dr. Bhuvanesh R</li>
          <li>Individualized Education Plans (IEP) for every child</li>
          <li>Data-driven progress tracking with evaluations every 3 months</li>
          <li>Parent training, coaching, and support groups</li>
          <li>Safe, sensory-friendly environment</li>
          <li>Small 1:3 / 1:2 teaching ratio for personalized attention</li>
          <li>Evidence-based AAC tools including Avaz and low-tech communication boards</li>
        </ul>
      </div>

      <!-- Indian-themed illustration -->
      <div class="image-wrapper">
        <IndianIllustration icon="💛" palette="saffron" minHeight="360px" />
      </div>

    </div>
  </section>

  <!-- 5. CTA strip -->
  <section class="cta-strip">
    <div class="container">
      <h2>Ready to start your child's journey?</h2>
      <p>We invite you to join our community, where we don't just teach — we create links that allow your child to soar.</p>
      <a href="/contact" class="btn btn-white">Contact Us Today</a>
    </div>
  </section>

</Layout>

<style>
  /* ---- Shared container ---- */
  .about-container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* Light grey background for alternating sections */
  .alt-bg {
    background: var(--color-bg-light);
  }

  /* ---- Two-column layout ---- */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* .reverse flips column order so image appears on the left */
  .reverse .content       { order: 1; }
  .reverse .image-wrapper { order: 0; }

  /* ---- Section headings ---- */
  h2 {
    color: var(--color-primary);
    font-size: 2rem;
    margin-bottom: 1.25rem;
  }

  p {
    line-height: 1.7;
    margin-bottom: 1.25rem;
    color: var(--color-text-body);
    font-size: 1.05rem;
  }

  /* ---- Images ---- */
  .image-wrapper img {
    width: 100%;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  /* ---- Philosophy cards (2×2 grid) ---- */
  .philosophy-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .philosophy-card {
    background: white;
    padding: 2rem;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    border: 1px solid #f3f4f6;
    transition: transform 0.2s;
  }

  .philosophy-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .card-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .philosophy-card h3 {
    color: var(--color-primary);
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .philosophy-card p {
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  /* ---- Why Choose Us checklist ---- */
  .check-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .check-list li {
    padding: 0.6rem 0;
    font-size: 1.05rem;
    color: var(--color-text-main);
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* Circular teal checkmark bullet */
  .check-list li::before {
    content: "✓";
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
  }

  /* ---- Mobile: stack everything vertically ---- */
  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    /* Always show text first on mobile; illustration is secondary */
    .reverse .content       { order: 0; }
    .reverse .image-wrapper { order: 1; }

    .philosophy-grid {
      grid-template-columns: 1fr;
    }

    /* Illustration shows below the text, compact and decorative */
    .image-wrapper {
      margin-bottom: 0;
    }

    /* Text sections left-aligned for comfortable mobile reading */
    .content {
      text-align: left;
    }

    /* Check-list items stay left-aligned */
    .check-list li {
      align-items: flex-start;
    }
  }
</style>
