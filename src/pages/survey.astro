---
// survey.astro — Embedded Google Form survey page
//
// ┌─────────────────────────────────────────────────────────────────────────┐
// │  TO CLOSE THE SURVEY: change surveyOpen to false                        │
// │  TO REOPEN THE SURVEY: change surveyOpen back to true                   │
// └─────────────────────────────────────────────────────────────────────────┘
const surveyOpen = true;

import Layout from '../layouts/Layout.astro';

const title       = "Share Your Feedback | Creating Links";
const description = "Help us improve our services by taking a short survey. Your feedback matters to us.";
---

<Layout title={title} description={description}>

  <section class="survey-hero">
    <div class="container">
      <h1>We'd love your feedback</h1>
      <p class="subtitle">This short survey helps us understand how we can better support you and your family. It takes about 2–3 minutes.</p>
    </div>
  </section>

  <section class="survey-section">
    <div class="container">

      {surveyOpen ? (
        <div class="form-wrapper">
          <iframe
            src="https://docs.google.com/forms/d/e/1FAIpQLScgKmBTOU27fA05i4-Y2rjMc5XjwEQiNmGVRHAtuRhtcpbznQ/viewform?embedded=true"
            width="100%"
            height="2196"
            frameborder="0"
            marginheight="0"
            marginwidth="0"
            title="Creating Links Feedback Survey"
          >
            Loading survey…
          </iframe>
          <p class="form-note">
            Having trouble viewing the form?
            <a href="https://docs.google.com/forms/d/e/1FAIpQLScgKmBTOU27fA05i4-Y2rjMc5XjwEQiNmGVRHAtuRhtcpbznQ/viewform" target="_blank" rel="noopener noreferrer">Open it in a new tab →</a>
          </p>
        </div>
      ) : (
        <div class="closed-message">
          <div class="closed-icon">🙏</div>
          <h2>Thank you for your interest!</h2>
          <p>We have collected enough responses for now and the survey is currently closed. We truly appreciate everyone who took the time to share their feedback — it means a great deal to us.</p>
          <p>If you'd like to get in touch, please <a href="/contact">reach out to us directly</a>.</p>
        </div>
      )}

    </div>
  </section>

</Layout>

<style>
  .survey-hero {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    padding: 3rem 1rem 2.5rem;
    text-align: center;
    border-bottom: 1px solid #d1fae5;
  }

  .survey-hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    color: #065f46;
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1.1rem;
    color: #374151;
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .survey-section {
    padding: 2.5rem 1rem 4rem;
  }

  .container {
    max-width: 820px;
    margin: 0 auto;
  }

  /* ── Embedded form ── */
  .form-wrapper {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    overflow: hidden;
  }

  .form-wrapper iframe {
    display: block;
    border: none;
    min-height: 900px;
  }

  .form-note {
    text-align: center;
    font-size: 0.85rem;
    color: #6b7280;
    padding: 0.75rem 1rem;
    background: #f9fafb;
    border-top: 1px solid #e5e7eb;
    margin: 0;
  }

  .form-note a {
    color: #059669;
    text-decoration: underline;
  }

  /* ── Closed state ── */
  .closed-message {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    padding: 3rem 2rem;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .closed-icon {
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }

  .closed-message h2 {
    font-size: 1.7rem;
    color: #065f46;
    margin-bottom: 1rem;
  }

  .closed-message p {
    color: #374151;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .closed-message a {
    color: #059669;
    font-weight: 600;
    text-decoration: underline;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .survey-hero {
      padding: 2rem 1rem 1.75rem;
    }

    .form-wrapper iframe {
      min-height: 2400px;
    }

    .closed-message {
      padding: 2rem 1.25rem;
    }
  }
</style>
