---
// =============================================================
// team.astro — Our Team page
//
// Section order:
//   1. Page header      (teal banner)
//   2. Featured founder (Dr. Bhuvanesh — large prominent card)
//   3. Other founders   (leadership grid — Shweta S)
//   4. Clinical team    (grid — other staff from team.json)
//   5. Hiring CTA       (orange strip)
//
// Data source: src/data/team.json
//   is_featured: true  → shown in the large "Lead Therapist" card
//   is_founder:  true  → shown in "Leadership Team" section
//   everything else    → shown in "Our Clinical Team" grid
// =============================================================

import Layout    from '../layouts/Layout.astro';
import teamData  from '../data/team.json';

// Split team members into three groups
const founders      = teamData.filter(member =>  member.is_founder);
const staff         = teamData.filter(member => !member.is_founder);
const featured      = founders.find(m =>  m.is_featured);    // Dr. Bhuvanesh
const otherFounders = founders.filter(m => !m.is_featured);  // Shweta S
---

<Layout
  title="Our Team — Creating Links"
  description="Meet the dedicated specialists at Creating Links — led by Dr. Bhuvanesh R, our multidisciplinary team is here for your child."
>

  <!-- 1. Page header banner -->
  <section class="page-header">
    <div class="container">
      <h1>Meet Our Specialists</h1>
      <p>A multidisciplinary team dedicated to your child's growth and independence.</p>
    </div>
  </section>

  <!-- 2. Featured founder: Dr. Bhuvanesh R (large card) -->
  {featured && (
    <section class="section">
      <div class="team-container">
        <div class="featured-card">

          <!-- Photo (left side) -->
          <div class="featured-image">
            <img src={featured.image} alt={featured.name} />
          </div>

          <!-- Bio (right side) -->
          <div class="featured-info">
            <span class="founder-badge">Lead Therapist</span>
            <h2>{featured.name}</h2>
            <span class="role">{featured.role}</span>
            <span class="quals">{featured.qualifications}</span>
            <p>{featured.bio}</p>
          </div>

        </div>
      </div>
    </section>
  )}

  <!-- 3. Other founders: Shweta S (leadership grid) -->
  {otherFounders.length > 0 && (
    <section class="section alt-bg">
      <div class="team-container">
        <h2 class="section-title">Leadership Team</h2>
        <div class="founders-grid">
          {otherFounders.map((member) => (
            <div class="profile-card founder-card">
              <div class="card-image">
                <img src={member.image} alt={member.name} />
              </div>
              <div class="card-info">
                <h3>{member.name}</h3>
                <span class="role">{member.role}</span>
                <span class="quals">{member.qualifications}</span>
                <p>{member.bio}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 4. Clinical team (therapists, educators, etc.) -->
  {staff.length > 0 && (
    <section class="section">
      <div class="team-container">
        <h2 class="section-title">Our Clinical Team</h2>
        <div class="team-grid">
          {staff.map((member) => (
            <div class="profile-card">
              <div class="card-image-small">
                <img src={member.image} alt={member.name} />
              </div>
              <div class="card-info">
                <h3>{member.name}</h3>
                <span class="role">{member.role}</span>
                <p>{member.bio}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 5. Hiring CTA strip -->
  <section class="cta-strip">
    <div class="container">
      <h2>Join Our Team</h2>
      <p>Are you a passionate therapist or educator? We are always looking for dedicated professionals.</p>
      <a href="/contact" class="btn btn-white">Apply Now</a>
    </div>
  </section>

</Layout>

<style>
  /* ---- Shared container ---- */
  .team-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* Light grey background for alternating sections */
  .alt-bg {
    background: var(--color-bg-light);
  }

  /* Centred section headings */
  .section-title {
    text-align: center;
    color: var(--color-primary);
    font-size: 2rem;
    margin-bottom: 2.5rem;
  }

  /* ---- Featured founder card (large, two-column) ---- */
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1.5fr;   /* photo narrower, bio wider */
    gap: 3rem;
    align-items: center;
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid #f3f4f6;
  }

  /* Photo fills the full height of the card */
  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 350px;
  }

  .featured-info {
    padding: 2.5rem 2.5rem 2.5rem 0;
  }

  /* "Lead Therapist" teal pill badge */
  .founder-badge {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: 0.3rem 0.75rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .featured-info h2 {
    font-size: 2rem;
    color: var(--color-text-main);
    margin-bottom: 0.25rem;
  }

  /* Orange role title */
  .role {
    display: block;
    color: var(--color-secondary);
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }

  /* Italic qualifications line */
  .quals {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 1rem;
  }

  .featured-info p {
    color: var(--color-text-body);
    line-height: 1.7;
    font-size: 1.05rem;
  }

  /* ---- Founders grid (side-by-side cards) ---- */
  .founders-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  /* ---- Profile card (shared by founders grid + clinical team) ---- */
  .profile-card {
    background: white;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid #f3f4f6;
    transition: transform 0.2s;
  }

  .profile-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  /* Founder cards have image on left, text on right */
  .founder-card {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    align-items: center;
  }

  /* Image fills card height for founder cards */
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Fixed height for clinical team card images */
  .card-image-small img {
    width: 100%;
    height: 260px;
    object-fit: cover;
  }

  .card-info {
    padding: 1.5rem;
  }

  .card-info h3 {
    color: var(--color-text-main);
    font-size: 1.2rem;
    margin-bottom: 0.2rem;
  }

  .card-info p {
    color: var(--color-text-body);
    line-height: 1.6;
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  /* ---- Clinical team grid ---- */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
  }

  /* ---- Mobile: single column ---- */
  @media (max-width: 768px) {
    /* Featured card stacks photo above bio */
    .featured-card {
      grid-template-columns: 1fr;
    }

    .featured-info {
      padding: 1.5rem;
    }

    /* Founder cards also stack vertically */
    .founder-card {
      grid-template-columns: 1fr;
    }
  }
</style>
