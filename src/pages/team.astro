---
import Layout from '../layouts/Layout.astro';
import teamData from '../data/team.json';

const founders = teamData.filter(member => member.is_founder);
const staff = teamData.filter(member => !member.is_founder);
const featured = founders.find(m => m.is_featured);
const otherFounders = founders.filter(m => !m.is_featured);
---

<Layout title="Our Team — Creating Links" description="Meet the dedicated specialists at Creating Links — led by Dr. Bhuvanesh R, our multidisciplinary team is here for your child.">

  <section class="page-header">
    <div class="container">
      <h1>Meet Our Specialists</h1>
      <p>A multidisciplinary team dedicated to your child's growth and independence.</p>
    </div>
  </section>

  <!-- Featured Founder (Dr. Bhuvanesh) -->
  {featured && (
    <section class="section">
      <div class="team-container">
        <div class="featured-card">
          <div class="featured-image">
            <img src={featured.image} alt={featured.name} />
          </div>
          <div class="featured-info">
            <span class="founder-badge">Lead Therapist</span>
            <h2>{featured.name}</h2>
            <span class="role">{featured.role}</span>
            <span class="quals">{featured.qualifications}</span>
            <p>{featured.bio}</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Other Founders -->
  {otherFounders.length > 0 && (
    <section class="section alt-bg">
      <div class="team-container">
        <h2 class="section-title">Leadership Team</h2>
        <div class="founders-grid">
          {otherFounders.map((member) => (
            <div class="profile-card founder-card">
              <div class="card-image">
                <img src={member.image} alt={member.name} />
              </div>
              <div class="card-info">
                <h3>{member.name}</h3>
                <span class="role">{member.role}</span>
                <span class="quals">{member.qualifications}</span>
                <p>{member.bio}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Clinical Team -->
  {staff.length > 0 && (
    <section class="section">
      <div class="team-container">
        <h2 class="section-title">Our Clinical Team</h2>
        <div class="team-grid">
          {staff.map((member) => (
            <div class="profile-card">
              <div class="card-image-small">
                <img src={member.image} alt={member.name} />
              </div>
              <div class="card-info">
                <h3>{member.name}</h3>
                <span class="role">{member.role}</span>
                <p>{member.bio}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Hiring CTA -->
  <section class="cta-strip">
    <div class="container">
      <h2>Join Our Team</h2>
      <p>Are you a passionate therapist or educator? We are always looking for dedicated professionals.</p>
      <a href="/contact" class="btn btn-white">Apply Now</a>
    </div>
  </section>

</Layout>

<style>
  .team-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .alt-bg { background: var(--color-bg-light); }

  .section-title {
    text-align: center;
    color: var(--color-primary);
    font-size: 2rem;
    margin-bottom: 2.5rem;
  }

  /* Featured Founder (large card) */
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    align-items: center;
    background: white;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid #f3f4f6;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    min-height: 350px;
  }

  .featured-info {
    padding: 2.5rem 2.5rem 2.5rem 0;
  }

  .founder-badge {
    display: inline-block;
    background: var(--color-primary-light);
    color: var(--color-primary);
    padding: 0.3rem 0.75rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .featured-info h2 {
    font-size: 2rem;
    color: var(--color-text-main);
    margin-bottom: 0.25rem;
  }

  .role {
    display: block;
    color: var(--color-secondary);
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }

  .quals {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 1rem;
  }

  .featured-info p {
    color: var(--color-text-body);
    line-height: 1.7;
    font-size: 1.05rem;
  }

  /* Founders Grid */
  .founders-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  /* Profile Card */
  .profile-card {
    background: white;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid #f3f4f6;
    transition: transform 0.2s;
  }
  .profile-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .founder-card {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    align-items: center;
  }

  .card-image img,
  .card-image-small img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .card-image-small img {
    height: 260px;
  }

  .card-info {
    padding: 1.5rem;
  }

  .card-info h3 {
    color: var(--color-text-main);
    font-size: 1.2rem;
    margin-bottom: 0.2rem;
  }

  .card-info p {
    color: var(--color-text-body);
    line-height: 1.6;
    font-size: 0.95rem;
    margin-bottom: 0;
  }

  /* Team Grid */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .featured-card {
      grid-template-columns: 1fr;
    }
    .featured-info {
      padding: 1.5rem;
    }
    .founder-card {
      grid-template-columns: 1fr;
    }
  }
</style>
