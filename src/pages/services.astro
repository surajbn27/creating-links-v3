---
import Layout from '../layouts/Layout.astro';
import servicesData from '../data/services.json';
---

<Layout title="Our Services — Creating Links" description="Explore our comprehensive therapy services including occupational therapy, speech therapy, school readiness, behavioral therapy, and more.">

  <section class="page-header">
    <div class="container">
      <h1>Our Clinical Services</h1>
      <p>Holistic, evidence-based therapies tailored to your child's unique developmental needs.</p>
    </div>
  </section>

  <!-- Quick Nav -->
  <section class="service-nav">
    <div class="container">
      <div class="nav-pills">
        {servicesData.map((service) => (
          <a href={`#${service.id}`} class="pill">
            <span class="pill-icon">{service.icon}</span>
            <span>{service.title.replace(/ \(.*\)/, '')}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Details -->
  <section class="services-content">
    <div class="container">
      {servicesData.map((service, index) => (
        <div class:list={["service-row", { reverse: index % 2 !== 0 }]} id={service.id}>
          <div class="text-col">
            <div class="icon-header">
              <span class="icon">{service.icon}</span>
              <div>
                <h2>{service.title}</h2>
                {service.subtitle && <span class="subtitle">{service.subtitle}</span>}
              </div>
            </div>
            <p>{service.description}</p>
            <ul class="benefits-list">
              {service.benefits.map((benefit) => (
                <li>{benefit}</li>
              ))}
            </ul>
          </div>
          <div class="img-col">
            <img src={service.image} alt={service.title} loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-strip">
    <div class="container">
      <h2>Not sure which service your child needs?</h2>
      <p>Book an initial assessment and let our multidisciplinary team guide you.</p>
      <a href="/contact" class="btn btn-white">Book Assessment</a>
    </div>
  </section>

</Layout>

<style>
  /* Quick nav pills */
  .service-nav {
    padding: 1.5rem 1.25rem;
    background: white;
    border-bottom: 1px solid #f3f4f6;
    position: sticky;
    top: var(--navbar-height);
    z-index: 50;
  }
  .nav-pills {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    scrollbar-width: none;
  }
  .nav-pills::-webkit-scrollbar { display: none; }
  .pill {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    background: var(--color-bg-light);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-main);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.2s;
    border: 1px solid transparent;
  }
  .pill:hover {
    background: var(--color-primary-light);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .pill-icon { font-size: 1rem; }

  /* Service content */
  .services-content {
    padding: 3rem 1.25rem;
  }

  .service-row {
    display: flex;
    gap: 3rem;
    align-items: center;
    padding: 3rem 0;
    border-bottom: 1px solid #f3f4f6;
  }
  .service-row:last-child {
    border-bottom: none;
  }

  .reverse {
    flex-direction: row-reverse;
  }

  .text-col { flex: 1; }
  .img-col { flex: 1; }

  .img-col img {
    width: 100%;
    height: 380px;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  .icon-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .icon { font-size: 2.25rem; }

  .icon-header h2 {
    color: var(--color-primary);
    font-size: 1.75rem;
    margin: 0;
    line-height: 1.2;
  }
  .subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    font-weight: 500;
    display: block;
    margin-top: 0.15rem;
  }

  p {
    line-height: 1.7;
    color: var(--color-text-body);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .benefits-list li {
    padding: 0.5rem 0;
    color: var(--color-text-main);
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .benefits-list li::before {
    content: "✓";
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .service-row, .reverse {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
      padding: 2rem 0;
    }
    .icon-header {
      justify-content: center;
    }
    .benefits-list li {
      justify-content: center;
    }
    .service-nav {
      top: 50px;
    }
  }
</style>
