---
// =============================================================
// services.astro — Full Services listing page
//
// Section order:
//   1. Page header    (teal banner)
//   2. Service nav    (sticky pill links, one per service)
//   3. Service rows   (alternating text-left / text-right layout)
//   4. CTA Strip      (book assessment)
//
// Data source: src/data/services.json
// Each service row has an id matching its services.json entry,
// so the sticky nav pill links scroll directly to it.
// =============================================================

import Layout              from '../layouts/Layout.astro';
import servicesData        from '../data/services.json';
import IndianIllustration  from '../components/IndianIllustration.astro';

// Cycle through colour palettes for alternating service rows
const palettes = ['teal', 'saffron', 'lotus', 'green', 'purple'] as const;
---

<Layout
  title="Our Services — Creating Links"
  description="Explore our comprehensive therapy services including occupational therapy, speech therapy, school readiness, behavioral therapy, and more."
>

  <!-- 1. Page header banner -->
  <section class="page-header">
    <div class="container">
      <h1>Our Clinical Services</h1>
      <p>Holistic, evidence-based therapies tailored to your child's unique developmental needs.</p>
    </div>
  </section>

  <!-- 2. Sticky quick-navigation pills -->
  <!--    top: var(--navbar-height) ensures it sits just below the navbar -->
  <section class="service-nav">
    <div class="container">
      <div class="nav-pills">
        {servicesData.map((service) => (
          <a href={`#${service.id}`} class="pill">
            <span class="pill-icon">{service.icon}</span>
            <span>{service.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Service detail rows (alternating layout via .reverse class) -->
  <section class="services-content">
    <div class="container">
      {servicesData.map((service, index) => (
        <div
          class:list={["service-row", { reverse: index % 2 !== 0 }]}
          id={service.id}
        >
          <!-- Text column -->
          <div class="text-col">
            <div class="icon-header">
              <span class="icon">{service.icon}</span>
              <div>
                <h2>{service.title}</h2>
                {/* Subtitle appears only if defined (e.g. Early Intervention "(1–3 Years)") */}
                {service.subtitle && <span class="subtitle">{service.subtitle}</span>}
              </div>
            </div>

            <p>{service.description}</p>

            <!-- Benefits list with teal checkmark bullets -->
            <ul class="benefits-list">
              {service.benefits.map((benefit) => (
                <li>{benefit}</li>
              ))}
            </ul>
          </div>

          <!-- Image column: Indian-themed illustrated visual -->
          <div class="img-col">
            <IndianIllustration
              icon={service.icon}
              palette={palettes[index % palettes.length]}
              minHeight="340px"
            />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 4. CTA strip -->
  <section class="cta-strip">
    <div class="container">
      <h2>Not sure which service your child needs?</h2>
      <p>Book an initial assessment and let our multidisciplinary team guide you.</p>
      <a href="/contact" class="btn btn-white">Book Assessment</a>
    </div>
  </section>

</Layout>

<style>
  /* ---- Sticky service navigation pills ---- */
  .service-nav {
    padding: 1.5rem 1.25rem;
    background: white;
    border-bottom: 1px solid #f3f4f6;
    position: sticky;
    top: var(--navbar-height);   /* sit just below the sticky navbar */
    z-index: 50;
  }

  /* Horizontally scrollable on narrow screens, hide scrollbar visually */
  .nav-pills {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    scrollbar-width: none;
  }
  .nav-pills::-webkit-scrollbar {
    display: none;
  }

  .pill {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    background: var(--color-bg-light);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-main);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.2s;
    border: 1px solid transparent;
  }

  .pill:hover {
    background: var(--color-primary-light);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .pill-icon {
    font-size: 1rem;
  }

  /* ---- Service content rows ---- */
  .services-content {
    padding: 3rem 1.25rem;
  }

  .service-row {
    display: flex;
    gap: 3rem;
    align-items: center;
    padding: 3rem 0;
    border-bottom: 1px solid #f3f4f6;
  }

  /* No border on the last row */
  .service-row:last-child {
    border-bottom: none;
  }

  /* Every other row has the image on the left */
  .reverse {
    flex-direction: row-reverse;
  }

  .text-col { flex: 1; }
  .img-col  { flex: 1; }

  /* Show the full image at its natural proportions — no cropping */
  .img-col img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  /* placeholder styles removed — replaced by IndianIllustration component */
  ._unused {
    /* keeping selector to avoid any accidental CSS removal side-effects */
    display: none;
  }

  /* ---- Service title row (icon + heading + optional subtitle) ---- */
  .icon-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .icon {
    font-size: 2.25rem;
  }

  .icon-header h2 {
    color: var(--color-primary);
    font-size: 1.75rem;
    margin: 0;
    line-height: 1.2;
  }

  /* Age range shown below the title e.g. "(1–3 Years)" */
  .subtitle {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    font-weight: 500;
    display: block;
    margin-top: 0.15rem;
  }

  /* Description paragraph — scoped to this page only */
  p {
    line-height: 1.7;
    color: var(--color-text-body);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  /* ---- Benefits list with circular checkmarks ---- */
  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .benefits-list li {
    padding: 0.5rem 0;
    color: var(--color-text-main);
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Circular teal ✓ bullet */
  .benefits-list li::before {
    content: "✓";
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: 50%;
    font-size: 0.7rem;
    font-weight: 700;
    flex-shrink: 0;   /* prevent bullet from shrinking on long text */
  }

  /* ---- Mobile: single column, illustration hidden ---- */
  @media (max-width: 768px) {

    /* Both normal and reversed rows stack the same way on mobile */
    .service-row,
    .reverse {
      flex-direction: column;
      gap: 0;
      padding: 2rem 0;
    }

    /* Hide illustrations — on mobile the text fills the full width cleanly */
    .img-col {
      display: none;
    }

    /* Left-align text for easier reading on mobile */
    .service-row,
    .reverse {
      text-align: left;
    }

    .icon-header {
      justify-content: flex-start;
    }

    .benefits-list li {
      justify-content: flex-start;
    }

    /* Adjust sticky nav offset on mobile (navbar is slightly shorter) */
    .service-nav {
      top: 50px;
    }
  }
</style>
